public class smallestNumber {
    public static void main(String[] args) {
        int[] a = {10, 20, 5, 40, 15};
        int smallest = a[0]; 
        for (int j=1;j<a.length;j++) {
            if (a[j]<smallest) {
                smallest = a[j];
            }
        }

        System.out.println(smallest);
    }
}
